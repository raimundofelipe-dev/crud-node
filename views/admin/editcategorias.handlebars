{{#each erros}}
<div class="alert alert-danger">{{texto}}</div>
{{else}}

{{/each}}

<form action="/admin/categorias/edit" method="POST">

    <input type="hidden" name="id" value="{{categoria.id}}">

    <h1>Editar Categoria:</h1>

    <label for="nome">Nome:</label>
    <input type="text" id="nome" name="nome" placeholder="Nome da categorias" class="form-control" value="{{categoria.nome}}">

    <label for="slug">Slug:</label>
    <input type="text" id="slug" name="slug" placeholder="Slug da categorias" class="form-control" value="{{categoria.slug}}">

    <hr>

    <button type="submit" class="btn btn-success">Editar categoria</button>

</form>