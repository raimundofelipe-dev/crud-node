<h1>Listas de Categorias:</h1>
<hr>
<a href="/admin/categorias/add"><button class="btn btn-success">Adicionar Categoria</button></a>

{{#each categorias}}
<div class="card mt-4">
    <div class="card-body">
        <h4>{{nome}}</h4>
        <small>Slug: {{slug}}</small><br>
        <small>Data: {{date}}</small>
        <br>
        <a href="/admin/categorias/edit/{{id}}"><button class="btn btn-success">Editar categoria</button></a>

        <form action="/admin/categorias/deletar" method="post">
            <input type="hidden" name="id" value="{{id}}">
            <button class="btn btn-danger mt-2">Excluir</button>
        </form>
    </div>
</div>
{{else}}

{{/each}}